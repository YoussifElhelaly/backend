PORT=8080
# Set to "release" in production (already set in Dockerfile ENV)
GIN_MODE=release

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=whatify
DB_SSLMODE=disable

# JWT — REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string-in-production

# CORS — comma-separated allowed frontend origins.
# Leave empty only in local dev. In production MUST be set to your frontend URL.
ALLOWED_ORIGINS=https://app.yourdomain.com

# Migrations — set to true in production to skip GORM AutoMigrate on startup.
# Run schema changes manually before each deploy when enabled.
DISABLE_AUTO_MIGRATE=false

# PayTabs — get from your PayTabs merchant dashboard: Developers > Key Management.
# Recurring token-based renewals require "Recurring" mode enabled on the
# profile by PayTabs support before the renewal worker can charge saved cards.
PAYTABS_PROFILE_ID=your_paytabs_profile_id
PAYTABS_SERVER_KEY=your_paytabs_server_key
# Region determines the API base URL: egypt | global | uae | ksa | jordan | oman
PAYTABS_REGION=egypt
PAYTABS_CURRENCY=EGP

FRONTEND_URL=https://app.yourdomain.com
# Used to build the PayTabs IPN callback URL sent with each checkout request.
BACKEND_URL=https://api.yourdomain.com

# Proxy Pool — auto-assigned round-robin to new sessions. Leave empty to disable.
# Supports socks5:// and http://. Manual proxy_url on a session always takes priority.
# Example: PROXY_POOL=socks5://user:pass@ip1:1080,socks5://user:pass@ip2:1080
PROXY_POOL=

# Super Admin (platform owner) — auto-created on first startup if set
SUPER_ADMIN_EMAIL=superadmin@whatify.io
SUPER_ADMIN_PASSWORD=change-me-secure-password

# SMTP — for password reset emails.
# Leave empty in local dev: emails are printed to stdout instead.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Whatify <noreply@yourdomain.com>

# AI Integration — AES-256 key for encrypting tenant API keys at rest.
# Generate with: openssl rand -hex 32
AI_ENCRYPTION_KEY=change-this-to-64-hex-chars-in-production
