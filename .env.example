PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=whatify
DB_SSLMODE=disable

# JWT — REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string-in-production

# CORS — comma-separated allowed frontend origins.
# Leave empty only in local dev. In production MUST be set to your frontend URL.
ALLOWED_ORIGINS=https://app.yourdomain.com

# Migrations — set to true in production to skip GORM AutoMigrate on startup.
# Run schema changes manually before each deploy when enabled.
DISABLE_AUTO_MIGRATE=false

# PayPal — get from https://developer.paypal.com/dashboard/
# Set PAYPAL_SANDBOX=true in development, false in production.
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_SANDBOX=true

# PayPal Billing Plan IDs — created automatically on first startup if not set.
# Copy the logged IDs here after the first run so they persist across restarts.
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_GROWTH=
PAYPAL_PLAN_SCALE=

FRONTEND_URL=https://app.yourdomain.com

# Super Admin (platform owner) — auto-created on first startup if set
SUPER_ADMIN_EMAIL=superadmin@whatify.io
SUPER_ADMIN_PASSWORD=change-me-secure-password

# SMTP — for password reset emails.
# Leave empty in local dev: emails are printed to stdout instead.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Whatify <noreply@yourdomain.com>
